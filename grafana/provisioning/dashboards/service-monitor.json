{
  "uid": "spring-boot-monitor",
  "title": "Spring Boot Monitor",
  "tags": ["spring-boot", "micrometer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "RPS", "type": "timeseries", "datasource": "Prometheus",
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "Requests/s", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2, "title": "5xx Errors", "type": "timeseries", "datasource": "Prometheus",
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "5xx", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3, "title": "Latency (Avg & p95)", "type": "timeseries", "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_sum[1m])) / sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "Avg", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))", "legendFormat": "p95", "refId": "B"}
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    },
    {
      "id": 4, "title": "JVM Memory (MB)", "type": "timeseries", "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{area=\"heap\"})/1048576", "legendFormat": "Heap", "refId": "A"},
        {"expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"})/1048576", "legendFormat": "Non-Heap", "refId": "B"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
    },
    {
      "id": 5, "title": "JVM Threads", "type": "timeseries", "datasource": "Prometheus",
      "targets": [{"expr": "jvm_threads_live_threads", "legendFormat": "Live", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    },
    {
      "id": 6, "title": "Entities Created", "type": "stat", "datasource": "Prometheus",
      "targets": [{"expr": "app_entities_total", "legendFormat": "Total", "refId": "A"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24}
    }
  ]
}
